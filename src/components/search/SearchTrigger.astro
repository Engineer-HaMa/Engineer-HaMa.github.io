---
import { site } from '@config/site';

// Default navigation actions shown before search query is typed
const navActions = [
  { id: 'nav-about', title: 'About', section: 'Navigation', href: `${site.base}/` },
  { id: 'nav-blog', title: 'Blog', section: 'Navigation', href: `${site.base}/blog/` },
  {
    id: 'nav-publications',
    title: 'Publications',
    section: 'Navigation',
    href: `${site.base}/publications/`,
  },
  { id: 'nav-projects', title: 'Projects', section: 'Navigation', href: `${site.base}/projects/` },
  { id: 'nav-cv', title: 'CV', section: 'Navigation', href: `${site.base}/cv/` },
  { id: 'nav-teaching', title: 'Teaching', section: 'Navigation', href: `${site.base}/teaching/` },
  { id: 'nav-people', title: 'People', section: 'Navigation', href: `${site.base}/people/` },
  { id: 'nav-books', title: 'Books', section: 'Navigation', href: `${site.base}/books/` },
  {
    id: 'nav-repositories',
    title: 'Repositories',
    section: 'Navigation',
    href: `${site.base}/repositories/`,
  },
];

const pagefindBase = site.base || '';
---

<!-- ninja-keys web component -->
<ninja-keys
  id="ninja-search"
  placeholder="Search or jump to…"
  hideBreadcrumbs
  data-nav-actions={JSON.stringify(navActions)}
  data-pagefind-base={pagefindBase}
></ninja-keys>

<script>
  import 'ninja-keys';

  async function initSearch() {
    await customElements.whenDefined('ninja-keys');

    /** @type {import('ninja-keys').NinjaKeys | null} */
    const nk = document.querySelector('#ninja-search') as any;
    if (!nk) return;

    const navActionsRaw = (nk as HTMLElement).dataset.navActions ?? '[]';
    const pagefindBase = (nk as HTMLElement).dataset.pagefindBase ?? '';
    const navActionsDefs: Array<{ id: string; title: string; section: string; href: string }> =
      JSON.parse(navActionsRaw);

    // Build default nav actions with click handlers
    const defaultData = navActionsDefs.map((item) => ({
      id: item.id,
      title: item.title,
      section: item.section,
      handler: () => {
        window.location.href = item.href;
      },
    }));

    nk.data = defaultData;

    // Open on search button click (both desktop + mobile #search-toggle buttons)
    document.querySelectorAll('#search-toggle').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        nk.open();
      });
    });

    // ⌘K / Ctrl+K keyboard shortcut
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        nk.open();
      }
    });

    // Pagefind integration — loaded lazily on first search
    let pagefind: any = null;

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import(/* @vite-ignore */ `${pagefindBase}/pagefind/pagefind.js`);
        await pagefind.init();
      } catch {
        // Pagefind not available in dev mode (requires a completed build)
        pagefind = null;
      }
      return pagefind;
    }

    nk.addEventListener('change', async (e: CustomEvent) => {
      const query = (e.detail?.search ?? '').trim();

      if (!query) {
        nk.data = defaultData;
        return;
      }

      const pf = await loadPagefind();
      if (!pf) {
        nk.data = defaultData;
        return;
      }

      const response = await pf.search(query);
      const results = await Promise.all(response.results.slice(0, 8).map((r: any) => r.data()));

      const searchData = results.map((item: any) => ({
        id: item.url,
        title: item.meta?.title || item.url,
        section: 'Search Results',
        description: item.excerpt?.replace(/<[^>]*>/g, '') ?? '',
        handler: () => {
          window.location.href = item.url;
        },
      }));

      nk.data = searchData.length > 0 ? searchData : defaultData;
    });
  }

  // Initialize on page load and after Astro view transitions
  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>

<style is:global>
  ninja-keys {
    --ninja-accent-color: var(--global-theme-color);
    --ninja-text-color: var(--global-text-color);
    --ninja-secondary-text-color: var(--global-text-color-light);
    --ninja-secondary-background-color: var(--global-bg-color);
    --ninja-selected-background: var(--global-hover-color);
    --ninja-icon-color: var(--global-text-color-light);
    --ninja-icon-size: 1rem;
    --ninja-separate-border: 1px solid var(--global-divider-color);
    --ninja-modal-background: var(--global-card-bg-color, var(--global-bg-color));
    --ninja-z-index: 9999;
    --ninja-modal-border-radius: 8px;
    --ninja-modal-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    --ninja-overflow-background: rgba(0, 0, 0, 0.5);
  }
</style>

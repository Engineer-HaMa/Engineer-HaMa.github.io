---
import { site } from '@config/site';
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { label: 'about', href: `${site.base}/` },
  { label: 'blog', href: `${site.base}/blog/` },
  { label: 'publications', href: `${site.base}/publications/` },
  { label: 'projects', href: `${site.base}/projects/` },
  { label: 'repositories', href: `${site.base}/repositories/` },
  { label: 'cv', href: `${site.base}/cv/` },
  { label: 'teaching', href: `${site.base}/teaching/` },
  { label: 'people', href: `${site.base}/people/` },
  { label: 'books', href: `${site.base}/books/` },
];

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === `${site.base}/`) return pathname === href || pathname === `${site.base}`;
  return pathname.startsWith(href);
}
---

<nav
  class="navbar fixed top-0 left-0 right-0 z-40"
  style="background-color: var(--global-bg-color); border-bottom: 1px solid var(--global-divider-color); opacity: 0.95; height: 57px;"
>
  <div
    class="page-container h-full flex items-center justify-between"
    style="max-width: 930px; margin: 0 auto; padding: 0 1rem;"
  >
    <!-- Brand -->
    <a
      href={`${site.base}/`}
      class="font-bold text-lg"
      style="color: var(--global-text-color); text-decoration: none;"
    >
      {site.author.name}
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`px-3 py-1 text-sm transition-colors ${isActive(item.href) ? 'font-bold' : ''}`}
            style={`color: ${isActive(item.href) ? 'var(--global-theme-color)' : 'var(--global-text-color)'}; text-decoration: none;`}
          >
            {item.label}
          </a>
        ))
      }

      <!-- Search trigger -->
      <button
        id="search-toggle"
        aria-label="Search (⌘K)"
        title="Search (⌘K)"
        style="padding: 0; border: 0; background: inherit; color: var(--global-text-color); cursor: pointer; margin-left: 0.5rem;"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>

      <ThemeToggle />
    </div>

    <!-- Mobile menu button -->
    <div class="flex md:hidden items-center gap-2">
      <button
        id="search-toggle"
        aria-label="Search"
        style="padding: 0; border: 0; background: inherit; color: var(--global-text-color); cursor: pointer;"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
      <ThemeToggle />
      <button
        id="navbar-toggler"
        class="navbar-toggler collapsed"
        aria-label="Toggle navigation"
        aria-expanded="false"
        style="padding: 0.25rem; border: 0; background: inherit; cursor: pointer;"
      >
        <span class="icon-bar top-bar" style="display: block; width: 22px; height: 2px; background-color: var(--global-text-color); border-radius: 1px; margin-bottom: 4px;"></span>
        <span class="icon-bar middle-bar" style="display: block; width: 22px; height: 2px; background-color: var(--global-text-color); border-radius: 1px; margin-bottom: 4px;"></span>
        <span class="icon-bar bottom-bar" style="display: block; width: 22px; height: 2px; background-color: var(--global-text-color); border-radius: 1px;"></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav dropdown -->
  <div
    id="navbar-collapse"
    class="md:hidden hidden"
    style="background-color: var(--global-bg-color); border-top: 1px solid var(--global-divider-color); padding: 0.5rem 0;"
  >
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="block px-4 py-2 text-sm"
          style={`color: ${isActive(item.href) ? 'var(--global-theme-color)' : 'var(--global-text-color)'}; font-weight: ${isActive(item.href) ? '700' : '400'}; text-decoration: none;`}
        >
          {item.label}
        </a>
      ))
    }
  </div>
</nav>

<style>
  .icon-bar {
    transition: all 0.2s;
  }

  /* When toggler is open (does NOT have .collapsed) */
  .navbar-toggler:not(.collapsed) .top-bar {
    transform: rotate(45deg);
    transform-origin: 10% 10%;
  }
  .navbar-toggler:not(.collapsed) .middle-bar {
    opacity: 0;
  }
  .navbar-toggler:not(.collapsed) .bottom-bar {
    transform: rotate(-45deg);
    transform-origin: 10% 90%;
  }

  /* When toggler is collapsed */
  .navbar-toggler.collapsed .top-bar {
    transform: rotate(0);
  }
  .navbar-toggler.collapsed .middle-bar {
    opacity: 1;
  }
  .navbar-toggler.collapsed .bottom-bar {
    transform: rotate(0);
  }
</style>

<script>
  const toggler = document.getElementById('navbar-toggler');
  const collapse = document.getElementById('navbar-collapse');

  toggler?.addEventListener('click', () => {
    const isOpen = !collapse?.classList.contains('hidden');
    if (isOpen) {
      collapse?.classList.add('hidden');
      toggler.setAttribute('aria-expanded', 'false');
      toggler.classList.add('collapsed');
      document.body.style.overflow = '';
    } else {
      collapse?.classList.remove('hidden');
      toggler.setAttribute('aria-expanded', 'true');
      toggler.classList.remove('collapsed');
      document.body.style.overflow = 'hidden';
    }
  });

  // Close on navigation — also restore scroll
  document.querySelectorAll('#navbar-collapse a').forEach((link) => {
    link.addEventListener('click', () => {
      collapse?.classList.add('hidden');
      toggler?.setAttribute('aria-expanded', 'false');
      toggler?.classList.add('collapsed');
      document.body.style.overflow = '';
    });
  });

  // Restore scroll on Astro view transitions (menu may be open during navigation)
  document.addEventListener('astro:before-swap', () => {
    document.body.style.overflow = '';
  });
</script>

---
import { site } from '@config/site';
import PostMeta from './PostMeta.astro';

interface Props {
  title: string;
  slug: string;
  date: Date | string;
  description?: string;
  tags?: string[];
  categories?: string[];
  readingTime?: number;
  /** External URL — overrides slug-based href and opens in a new tab */
  externalUrl?: string;
  /** Show full excerpt or compact card */
  compact?: boolean;
}

const {
  title,
  slug,
  date,
  description,
  tags = [],
  categories = [],
  readingTime,
  externalUrl,
  compact = false,
} = Astro.props;

const href = externalUrl ?? `${site.base}/blog/${slug}/`;
const isExternal = Boolean(externalUrl);
---

<article class={`post-card ${compact ? 'compact' : ''} mb-6`}>
  <div
    style="border-bottom: 1px solid var(--global-divider-color); padding-bottom: 1.5rem;"
  >
    <h2 class="text-xl font-bold mb-1" style="font-family: var(--font-sans);">
      <a
        href={href}
        style="color: var(--global-text-color); text-decoration: none;"
        class="post-title-link"
        {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {title}
        {isExternal && <span style="font-size: 0.7em; opacity: 0.6; margin-left: 0.25em;">↗</span>}
      </a>
    </h2>

    <PostMeta date={date} tags={tags} categories={categories} readingTime={readingTime} />

    {
      description && !compact && (
        <p class="mt-2 text-sm" style="color: var(--global-text-color-light); line-height: 1.6;">
          {description}
        </p>
      )
    }
  </div>
</article>

<style>
  .post-title-link:hover {
    color: var(--global-theme-color) !important;
  }
</style>

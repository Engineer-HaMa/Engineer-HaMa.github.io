---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { site } from '@config/site';
import { readingTime } from '@utils/reading-time';

/** A local post from the 'posts' collection. */
type LocalPost = CollectionEntry<'posts'>;

/** A synthetic external post object (constructed in blog listing pages). */
interface ExternalPost {
  external: true;
  id: string;
  url: string;
  data: {
    title: string;
    date: Date;
    description?: string;
    tags: string[];
    categories: string[];
    image?: string;
  };
  body?: undefined;
}

type PostEntry = LocalPost | ExternalPost;

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;

const isExternal = 'external' in post && post.external === true;

const title = post.data.title;
const date = post.data.date;
const description = post.data.description;
const tags = post.data.tags ?? [];
const categories = post.data.categories ?? [];
// Use `image` field as thumbnail (matches schema field name)
const thumbnail = (post.data as { image?: string }).image;

const href = isExternal
  ? (post as ExternalPost).url
  : `${site.base}/blog/${post.id}/`;

const minutes = !isExternal && (post as LocalPost).body
  ? readingTime((post as LocalPost).body!)
  : undefined;

const d = date instanceof Date ? date : new Date(date);
const formattedDate = d.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const year = d.getFullYear();
---

{thumbnail ? (
  <div class="row">
    <div class="col-sm-9">
      <h3>
        <a
          class="post-title"
          href={href}
          {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {title}
          {isExternal && <span style="font-size: 0.7em; opacity: 0.6; margin-left: 0.25em;">&#x2197;</span>}
        </a>
      </h3>
      {description && <p>{description}</p>}
      <p class="post-meta">
        {minutes && <>{minutes} min read &nbsp;&middot;&nbsp; </>}
        <time datetime={d.toISOString()}>{formattedDate}</time>
      </p>
      <p class="post-tags">
        <a href={`${site.base}/blog/`}>
          <Icon name="fa-solid:calendar" />&nbsp;{year}
        </a>
        {tags.map((tag) => (
          <>
            &nbsp;&middot;&nbsp;
            <a href={`${site.base}/blog/tag/${tag}/`}>
              <Icon name="fa-solid:hashtag" />&nbsp;{tag}
            </a>
          </>
        ))}
        {categories.map((cat) => (
          <>
            &nbsp;&middot;&nbsp;
            <a href={`${site.base}/blog/category/${cat}/`}>
              <Icon name="fa-solid:tag" />&nbsp;{cat}
            </a>
          </>
        ))}
      </p>
    </div>
    <div class="col-sm-3">
      <img
        class="img-fluid rounded z-depth-1"
        src={thumbnail}
        alt=""
        loading="lazy"
      />
    </div>
  </div>
) : (
  <>
    <h3>
      <a
        class="post-title"
        href={href}
        {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {title}
        {isExternal && <span style="font-size: 0.7em; opacity: 0.6; margin-left: 0.25em;">&#x2197;</span>}
      </a>
    </h3>
    {description && <p>{description}</p>}
    <p class="post-meta">
      {minutes && <>{minutes} min read &nbsp;&middot;&nbsp; </>}
      <time datetime={d.toISOString()}>{formattedDate}</time>
    </p>
    <p class="post-tags">
      <a href={`${site.base}/blog/`}>
        <Icon name="fa-solid:calendar" />&nbsp;{year}
      </a>
      {tags.map((tag) => (
        <>
          &nbsp;&middot;&nbsp;
          <a href={`${site.base}/blog/tag/${tag}/`}>
            <Icon name="fa-solid:hashtag" />&nbsp;{tag}
          </a>
        </>
      ))}
      {categories.map((cat) => (
        <>
          &nbsp;&middot;&nbsp;
          <a href={`${site.base}/blog/category/${cat}/`}>
            <Icon name="fa-solid:tag" />&nbsp;{cat}
          </a>
        </>
      ))}
    </p>
  </>
)}

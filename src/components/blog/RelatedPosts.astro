---
import type { CollectionEntry } from 'astro:content';
import { site } from '@config/site';
import PostMeta from './PostMeta.astro';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
if (posts.length === 0) return;
---

<section class="related-posts mt-12 pt-8" style="border-top: 1px solid var(--global-divider-color);">
  <h3
    class="text-lg font-bold mb-4"
    style="color: var(--global-text-color); font-family: var(--font-condensed);"
  >
    Related Posts
  </h3>

  <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
    {
      posts.map((post) => (
        <a
          href={`${site.base}/blog/${post.id}/`}
          class="related-card block rounded p-3 no-underline"
          style="border: 1px solid var(--global-divider-color); text-decoration: none;"
        >
          <h4
            class="text-sm font-semibold mb-1 related-title"
            style="color: var(--global-text-color); line-height: 1.4;"
          >
            {post.data.title}
          </h4>
          <PostMeta date={post.data.date} tags={post.data.tags} />
        </a>
      ))
    }
  </div>
</section>

<style>
  .related-card:hover {
    background-color: var(--global-hover-color);
    border-color: var(--global-theme-color) !important;
  }

  .related-card:hover .related-title {
    color: var(--global-theme-color) !important;
  }
</style>

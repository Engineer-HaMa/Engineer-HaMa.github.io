---
import { site } from '@config/site';

const year = new Date().getFullYear();
const lastUpdated = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<footer
  style="background-color: var(--global-footer-bg-color); color: var(--global-footer-text-color); padding: 1rem 0; margin-top: auto; position: sticky; bottom: 0;"
>
  <div class="page-container text-center text-sm">
    <p>
      &copy; {year} {site.author.name}.
      {site.footer.text && <span set:html={site.footer.text} />}
      {
        site.footer.lastUpdated && (
          <span class="ml-2">Last updated: {lastUpdated}.</span>
        )
      }
    </p>
    {
      site.footer.impressum && (
        <p class="mt-1">
          <a
            href={site.footer.impressum}
            style="color: var(--global-footer-link-color); text-decoration: none;"
          >
            Legal Notice
          </a>
        </p>
      )
    }
  </div>
</footer>

<style>
  footer a {
    color: var(--global-footer-link-color);
  }

  footer a:hover {
    color: var(--global-footer-text-color);
    text-decoration: underline;
  }
</style>

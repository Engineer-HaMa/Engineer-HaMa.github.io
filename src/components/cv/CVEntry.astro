---
interface Props {
  /** Main title line (job title, degree, paper title). */
  title: string;
  /** Secondary line (institution, company, journal). */
  subtitle?: string;
  /** Location string. */
  location?: string;
  /** Date range or single date string (already formatted). */
  dates?: string;
  /** Bullet points. */
  highlights?: string[];
  /** URL to make the title a link. */
  url?: string;
}

const { title, subtitle, location, dates, highlights = [], url } = Astro.props;
---

<div class="cv-entry mb-4">
  <div class="flex flex-wrap items-baseline justify-between gap-x-4">
    <div class="flex-1 min-w-0">
      {
        url ? (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold"
            style="color: var(--global-text-color); text-decoration: none;"
          >
            {title}
          </a>
        ) : (
          <span class="font-semibold" style="color: var(--global-text-color);">
            {title}
          </span>
        )
      }
      {
        subtitle && (
          <span class="text-sm" style="color: var(--global-text-color-light);">
            {' '}
            — {subtitle}
          </span>
        )
      }
      {
        location && (
          <span class="text-sm" style="color: var(--global-text-color-light);">
            , {location}
          </span>
        )
      }
    </div>
    {
      dates && (
        <div
          class="text-sm flex-shrink-0"
          style="color: var(--global-text-color-light); font-style: italic;"
        >
          {dates}
        </div>
      )
    }
  </div>

  {
    highlights.length > 0 && (
      <ul class="mt-1 ml-4 text-sm space-y-0.5" style="color: var(--global-text-color);">
        {highlights.map((h) => (
          <li class="list-disc" set:html={h} />
        ))}
      </ul>
    )
  }
</div>

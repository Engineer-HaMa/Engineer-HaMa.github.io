---
interface Props {
  /** Main title line (job title, degree, paper title). */
  title: string;
  /** Secondary line (institution, company, journal). */
  subtitle?: string;
  /** Location string — shown below date badge. */
  location?: string;
  /** Date range or single date string (already formatted). */
  dates?: string;
  /** Bullet points. */
  highlights?: string[];
  /** URL to make the title a link. */
  url?: string;
}

const { title, subtitle, location, dates, highlights = [], url } = Astro.props;
---

<li class="list-group-item">
  <div class="row">
    <div class="col-xs-2 col-sm-2 col-md-2 text-center date-column">
      <table class="table-cv">
        <tbody>
          <tr>
            <td>
              {dates && (
                <span
                  class="badge font-weight-bold danger-color-dark text-uppercase align-middle"
                  style="min-width: 75px;"
                >
                  {dates}
                </span>
              )}
            </td>
          </tr>
          {location && (
            <tr>
              <td>
                <p class="location">{location}</p>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
    <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">
      {url ? (
        <h6 class="title font-weight-bold ml-1 ml-md-4">
          <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
        </h6>
      ) : (
        <h6 class="title font-weight-bold ml-1 ml-md-4">{title}</h6>
      )}
      {subtitle && (
        <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem;">{subtitle}</h6>
      )}
      {highlights.length > 0 && (
        <ul class="items">
          {highlights.map((h) => (
            <li><span class="item" set:html={h} /></li>
          ))}
        </ul>
      )}
    </div>
  </div>
</li>

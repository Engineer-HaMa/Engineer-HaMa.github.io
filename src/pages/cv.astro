---
import yaml from 'js-yaml';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import CVSection from '@components/cv/CVSection.astro';
import CVEntry from '@components/cv/CVEntry.astro';
import type { RenderCV, JSONResume, RenderCVEntry } from '@utils/cv';
import { formatDateRange, formatCVDate } from '@utils/cv';
import cvRaw from '../data/cv.yml?raw';
import resumeData from '../data/resume.json';

const format = site.cv.format;

// Parse data based on format
const renderCV = format === 'rendercv' ? (yaml.load(cvRaw) as RenderCV) : null;
const jsonResume = format === 'jsonresume' ? (resumeData as JSONResume) : null;

// Pre-compute RenderCV sections to avoid TypeScript generics in JSX
const rc = renderCV?.cv ?? null;
const rcName = rc?.name ?? '';
const education = (rc?.sections?.education ?? []) as RenderCVEntry[];
const experience = (rc?.sections?.experience ?? []) as RenderCVEntry[];
const rcPublications = (rc?.sections?.publications ?? []) as RenderCVEntry[];
const awards = (rc?.sections?.awards ?? []) as RenderCVEntry[];
const skills = (rc?.sections?.skills ?? []) as RenderCVEntry[];
const interests = (rc?.sections?.interests ?? []) as RenderCVEntry[];

// Pre-compute JSONResume sections
const jr = jsonResume ?? null;
const jrName = jr?.basics?.name ?? '';
const jrLabel = jr?.basics?.label ?? '';
---

<Page title="CV" description={`Curriculum vitae of ${site.author.name}`}>
  <!-- Header row: name + download button -->
  <div class="flex items-start justify-between mb-8 flex-wrap gap-4">
    <div>
      <h1
        class="text-3xl font-bold"
        style="color: var(--global-text-color); font-family: var(--font-sans);"
      >
        {format === 'rendercv' ? rcName : jrName}
      </h1>
      {jrLabel && format === 'jsonresume' && (
        <p class="text-base mt-1" style="color: var(--global-text-color-light);">{jrLabel}</p>
      )}
    </div>

    {site.cv.pdfPath && (
      <a
        href={site.cv.pdfPath}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded"
        style="background-color: var(--global-theme-color); color: var(--global-hover-text-color); text-decoration: none;"
      >
        Download PDF
      </a>
    )}
  </div>

  <!-- ── RENDERCV ──────────────────────────────────────────────────────── -->
  {format === 'rendercv' && renderCV && (
    <>
      {education.length > 0 && (
        <CVSection title="Education" id="education">
          {education.map((e) => (
            <CVEntry
              title={`${e.degree ?? ''} in ${e.area ?? ''}`}
              subtitle={e.institution}
              dates={formatDateRange(e.start_date, e.end_date)}
              highlights={e.highlights}
            />
          ))}
        </CVSection>
      )}

      {experience.length > 0 && (
        <CVSection title="Experience" id="experience">
          {experience.map((e) => (
            <CVEntry
              title={e.position ?? ''}
              subtitle={e.company}
              location={e.location}
              dates={formatDateRange(e.start_date, e.end_date)}
              highlights={e.highlights}
            />
          ))}
        </CVSection>
      )}

      {rcPublications.length > 0 && (
        <CVSection title="Selected Publications" id="publications">
          {rcPublications.map((e) => (
            <CVEntry
              title={e.title ?? ''}
              subtitle={[e.authors?.join(', '), e.journal].filter(Boolean).join(' — ')}
              dates={formatCVDate(e.date)}
              url={e.doi ? `https://doi.org/${e.doi}` : e.url}
            />
          ))}
        </CVSection>
      )}

      {awards.length > 0 && (
        <CVSection title="Honors & Awards" id="awards">
          {awards.map((e) => (
            <CVEntry
              title={e.name ?? ''}
              subtitle={e.issuer}
              dates={formatCVDate(e.date)}
              highlights={e.highlights}
            />
          ))}
        </CVSection>
      )}

      {skills.length > 0 && (
        <CVSection title="Skills" id="skills">
          <dl class="grid gap-1 text-sm">
            {skills.map((e) => (
              <div class="flex flex-wrap gap-x-3">
                <dt class="font-semibold" style="color: var(--global-text-color); min-width: 8rem;">
                  {e.label}
                </dt>
                <dd style="color: var(--global-text-color-light);">{e.details}</dd>
              </div>
            ))}
          </dl>
        </CVSection>
      )}

      {interests.length > 0 && (
        <CVSection title="Interests" id="interests">
          <dl class="grid gap-1 text-sm">
            {interests.map((e) => (
              <div class="flex flex-wrap gap-x-3">
                <dt class="font-semibold" style="color: var(--global-text-color); min-width: 8rem;">
                  {e.label}
                </dt>
                <dd style="color: var(--global-text-color-light);">{e.details}</dd>
              </div>
            ))}
          </dl>
        </CVSection>
      )}
    </>
  )}

  <!-- ── JSONRESUME ────────────────────────────────────────────────────── -->
  {format === 'jsonresume' && jsonResume && (
    <>
      {jr?.education && jr.education.length > 0 && (
        <CVSection title="Education" id="education">
          {jr.education.map((e) => (
            <CVEntry
              title={`${e.studyType ?? ''} in ${e.area ?? ''}`}
              subtitle={e.institution}
              url={e.url}
              dates={formatDateRange(e.startDate, e.endDate)}
              highlights={e.courses}
            />
          ))}
        </CVSection>
      )}

      {jr?.work && jr.work.length > 0 && (
        <CVSection title="Experience" id="experience">
          {jr.work.map((e) => (
            <CVEntry
              title={e.position ?? ''}
              subtitle={e.name}
              url={e.url}
              dates={formatDateRange(e.startDate, e.endDate)}
              highlights={e.highlights}
            />
          ))}
        </CVSection>
      )}

      {jr?.publications && jr.publications.length > 0 && (
        <CVSection title="Selected Publications" id="publications">
          {jr.publications.map((e) => (
            <CVEntry
              title={e.name ?? ''}
              subtitle={e.publisher}
              url={e.url}
              dates={formatCVDate(e.releaseDate)}
              highlights={e.summary ? [e.summary] : []}
            />
          ))}
        </CVSection>
      )}

      {jr?.awards && jr.awards.length > 0 && (
        <CVSection title="Honors & Awards" id="awards">
          {jr.awards.map((e) => (
            <CVEntry
              title={e.title ?? ''}
              subtitle={e.awarder}
              dates={formatCVDate(e.date)}
              highlights={e.summary ? [e.summary] : []}
            />
          ))}
        </CVSection>
      )}

      {jr?.skills && jr.skills.length > 0 && (
        <CVSection title="Skills" id="skills">
          <dl class="grid gap-1 text-sm">
            {jr.skills.map((e) => (
              <div class="flex flex-wrap gap-x-3">
                <dt class="font-semibold" style="color: var(--global-text-color); min-width: 8rem;">
                  {e.name}
                </dt>
                <dd style="color: var(--global-text-color-light);">{e.keywords?.join(', ')}</dd>
              </div>
            ))}
          </dl>
        </CVSection>
      )}

      {jr?.languages && jr.languages.length > 0 && (
        <CVSection title="Languages" id="languages">
          <dl class="grid gap-1 text-sm">
            {jr.languages.map((e) => (
              <div class="flex flex-wrap gap-x-3">
                <dt class="font-semibold" style="color: var(--global-text-color); min-width: 8rem;">
                  {e.language}
                </dt>
                <dd style="color: var(--global-text-color-light);">{e.fluency}</dd>
              </div>
            ))}
          </dl>
        </CVSection>
      )}

      {jr?.interests && jr.interests.length > 0 && (
        <CVSection title="Interests" id="interests">
          <dl class="grid gap-1 text-sm">
            {jr.interests.map((e) => (
              <div class="flex flex-wrap gap-x-3">
                <dt class="font-semibold" style="color: var(--global-text-color); min-width: 8rem;">
                  {e.name}
                </dt>
                <dd style="color: var(--global-text-color-light);">{e.keywords?.join(', ')}</dd>
              </div>
            ))}
          </dl>
        </CVSection>
      )}
    </>
  )}
</Page>

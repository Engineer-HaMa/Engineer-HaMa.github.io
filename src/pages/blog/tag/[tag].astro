---
import { getCollection } from 'astro:content';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import PostCard from '@components/blog/PostCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  // Include all tags found in posts PLUS any tags listed in displayTags config
  const postTags = allPosts.flatMap((p) => p.data.tags);
  const allTags = [...new Set([...postTags, ...site.blog.displayTags])];

  return allTags.map((tag) => ({
    params: { tag },
    props: {
      posts: allPosts
        .filter((p) => !p.data.hidden && p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Page title={`Tag: ${tag}`} description={`Posts tagged "${tag}"`}>
  <div class="mb-6">
    <a
      href={`${site.base}/blog/`}
      class="text-sm"
      style="color: var(--global-theme-color); text-decoration: none;"
    >
      &larr; All posts
    </a>
  </div>

  <h1
    class="text-3xl font-bold mb-6"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    Posts tagged
    <span
      class="badge-abbr ml-2"
      style="background-color: var(--global-theme-color); color: var(--global-hover-text-color);"
    >
      {tag}
    </span>
  </h1>

  {
    posts.length === 0 ? (
      <p style="color: var(--global-text-color-light);">No posts found for this tag.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    )
  }
</Page>

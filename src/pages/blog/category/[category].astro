---
import { getCollection } from 'astro:content';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import PostCard from '@components/blog/PostCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  // Include all categories found in posts PLUS any categories listed in displayCategories config
  const postCategories = allPosts.flatMap((p) => p.data.categories);
  const allCategories = [...new Set([...postCategories, ...site.blog.displayCategories])];

  return allCategories.map((category) => ({
    params: { category },
    props: {
      posts: allPosts
        .filter((p) => !p.data.hidden && p.data.categories.includes(category))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { category } = Astro.params;
const { posts } = Astro.props;
---

<Page title={`Category: ${category}`} description={`Posts in category "${category}"`}>
  <div class="mb-6">
    <a
      href={`${site.base}/blog/`}
      class="text-sm"
      style="color: var(--global-theme-color); text-decoration: none;"
    >
      &larr; All posts
    </a>
  </div>

  <h1
    class="text-3xl font-bold mb-6"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    Category:
    <span
      class="badge-abbr ml-2"
      style="background-color: var(--global-text-color-light); color: var(--global-hover-text-color);"
    >
      {category}
    </span>
  </h1>

  {
    posts.length === 0 ? (
      <p style="color: var(--global-text-color-light);">No posts found for this category.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    )
  }
</Page>

---
import { getCollection } from 'astro:content';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { readingTime } from '@utils/reading-time';
import { fetchExternalPosts } from '@utils/external-posts';

const localPosts = (await getCollection('posts'))
  .filter((p) => !p.data.hidden)
  .sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.date.getTime() - a.data.date.getTime();
  });

const externalPosts = await fetchExternalPosts();

// Merge and sort all posts by date (local posts pinned first)
type LocalPost = (typeof localPosts)[number];
type MixedPost = LocalPost | { external: true; data: { title: string; date: Date; description?: string; tags: string[]; categories: string[] }; id: string; url: string };

const allPosts: MixedPost[] = [
  ...localPosts,
  ...externalPosts.map((ep) => ({
    external: true as const,
    id: ep.url,
    url: ep.url,
    data: {
      title: ep.title,
      date: ep.publishedDate,
      description: ep.description,
      tags: ep.tags,
      categories: ep.categories,
    },
  })),
].sort((a, b) => {
  const aPin = 'data' in a && 'pinned' in a.data ? (a.data as { pinned?: boolean }).pinned : false;
  const bPin = 'data' in b && 'pinned' in b.data ? (b.data as { pinned?: boolean }).pinned : false;
  if (aPin !== bPin) return aPin ? -1 : 1;
  return b.data.date.getTime() - a.data.date.getTime();
});

const perPage = site.blog.postsPerPage;
const totalPages = Math.ceil(allPosts.length / perPage);
const pagePosts = allPosts.slice(0, perPage);

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();
const allCategories = [...new Set(allPosts.flatMap((p) => p.data.categories))].sort();
---

<Page title="Blog" description={site.blog.description}>
  <h1
    class="text-3xl font-bold mb-2"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    {site.blog.name}
  </h1>
  <p class="mb-6 text-sm" style="color: var(--global-text-color-light);">
    {site.blog.description}
  </p>

  <!-- Tag filters -->
  {
    (site.blog.displayTags.length > 0 || allTags.length > 0) && (
      <div class="flex flex-wrap gap-2 mb-6">
        {allTags.map((tag) => (
          <a
            href={`${site.base}/blog/tag/${tag}/`}
            class="badge-abbr text-xs"
            style="background-color: var(--global-theme-color); color: var(--global-hover-text-color);"
          >
            {tag}
          </a>
        ))}
        {allCategories.map((cat) => (
          <a
            href={`${site.base}/blog/category/${cat}/`}
            class="badge-abbr text-xs"
            style="background-color: var(--global-text-color-light); color: var(--global-hover-text-color);"
          >
            {cat}
          </a>
        ))}
      </div>
    )
  }

  <!-- Post list -->
  {
    pagePosts.length === 0 ? (
      <p style="color: var(--global-text-color-light);">No posts yet. Check back soon!</p>
    ) : (
      pagePosts.map((post) =>
        'external' in post && post.external ? (
          <PostCard
            title={post.data.title}
            slug=""
            externalUrl={post.url}
            date={post.data.date}
            description={post.data.description}
            tags={post.data.tags}
            categories={post.data.categories}
          />
        ) : (
          <PostCard
            title={(post as LocalPost).data.title}
            slug={(post as LocalPost).id}
            date={(post as LocalPost).data.date}
            description={(post as LocalPost).data.description}
            tags={(post as LocalPost).data.tags}
            categories={(post as LocalPost).data.categories}
            readingTime={(post as LocalPost).body ? readingTime((post as LocalPost).body!) : undefined}
          />
        )
      )
    )
  }

  <Pagination
    currentPage={1}
    totalPages={totalPages}
    prevUrl={undefined}
    nextUrl={totalPages > 1 ? `${site.base}/blog/page/2/` : undefined}
    basePath={`${site.base}/blog/`}
  />
</Page>

---
import { getCollection } from 'astro:content';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.importance ?? 999) - (b.data.importance ?? 999)
);

// Collect unique categories preserving first-appearance order
const categories: string[] = [];
for (const p of projects) {
  if (p.data.category && !categories.includes(p.data.category)) {
    categories.push(p.data.category);
  }
}
const hasCategories = categories.length > 0;
---

<Page title="Projects" description={`Projects by ${site.author.name}`}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">projects</h1>
      <p class="post-description">A growing collection of your cool projects.</p>
    </header>

    <article>
      <div class="projects">
        {projects.length === 0 ? (
          <p style="color: var(--global-text-color-light);">No projects yet.</p>
        ) : hasCategories ? (
          categories.map((cat) => {
            const catProjects = projects.filter((p) => p.data.category === cat);
            return (
              <>
                <a id={cat} href={`#${cat}`}>
                  <h2 class="category">{cat}</h2>
                </a>
                <div class="projects-grid">
                  {catProjects.map((project) => {
                    const href = project.data.redirect ?? project.data.url ?? `${site.base}/projects/${project.id}/`;
                    const isExternal = !!(project.data.redirect);
                    return (
                      <div class="col">
                        <div
                          class="card h-100 hoverable"
                          data-href={href}
                          data-external={isExternal ? 'true' : undefined}
                          role="link"
                          tabindex="0"
                        >
                          {project.data.img && (
                            <img
                              src={project.data.img}
                              alt={project.data.img_alt ?? project.data.title}
                              loading="eager"
                              class="card-img-top"
                            />
                          )}
                          <div class="card-body">
                            <h2 class="card-title">{project.data.title}</h2>
                            {project.data.description && (
                              <p class="card-text">{project.data.description}</p>
                            )}
                            {project.data.github && (
                              <div class="row-icons">
                                <div class="github-icon">
                                  <div class="icon" title="Code Repository">
                                    <a
                                      href={`https://github.com/${project.data.github}`}
                                      target="_blank"
                                      rel="noopener noreferrer"
                                      aria-label={`${project.data.title} on GitHub`}
                                    >
                                      <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 16 16"
                                        fill="currentColor"
                                        class="gh-icon"
                                        aria-hidden="true"
                                      >
                                        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                                      </svg>
                                    </a>
                                  </div>
                                  {project.data.github_stars && (
                                    <span class="stars" title="GitHub Stars">
                                      <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 16 16"
                                        fill="currentColor"
                                        width="12"
                                        height="12"
                                        aria-hidden="true"
                                      >
                                        <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
                                      </svg>
                                      <span data-github-stars={project.data.github_stars}></span>
                                    </span>
                                  )}
                                </div>
                              </div>
                            )}
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </>
            );
          })
        ) : (
          <div class="projects-grid">
            {projects.map((project) => {
              const href = project.data.redirect ?? project.data.url ?? `${site.base}/projects/${project.id}/`;
              const isExternal = !!(project.data.redirect);
              return (
                <div class="col">
                  <div
                    class="card h-100 hoverable"
                    data-href={href}
                    data-external={isExternal ? 'true' : undefined}
                    role="link"
                    tabindex="0"
                  >
                    {project.data.img && (
                      <img
                        src={project.data.img}
                        alt={project.data.img_alt ?? project.data.title}
                        loading="eager"
                        class="card-img-top"
                      />
                    )}
                    <div class="card-body">
                      <h2 class="card-title">{project.data.title}</h2>
                      {project.data.description && (
                        <p class="card-text">{project.data.description}</p>
                      )}
                      {project.data.github && (
                        <div class="row-icons">
                          <div class="github-icon">
                            <div class="icon" title="Code Repository">
                              <a
                                href={`https://github.com/${project.data.github}`}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label={`${project.data.title} on GitHub`}
                              >
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  viewBox="0 0 16 16"
                                  fill="currentColor"
                                  class="gh-icon"
                                  aria-hidden="true"
                                >
                                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                                </svg>
                              </a>
                            </div>
                            {project.data.github_stars && (
                              <span class="stars" title="GitHub Stars">
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  viewBox="0 0 16 16"
                                  fill="currentColor"
                                  width="12"
                                  height="12"
                                  aria-hidden="true"
                                >
                                  <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
                                </svg>
                                <span data-github-stars={project.data.github_stars}></span>
                              </span>
                            )}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>
    </article>
  </div>
</Page>

<script>
  function initCards() {
    // Make cards clickable while allowing inner links to work independently
    document.querySelectorAll<HTMLElement>('.card[data-href]').forEach((card) => {
      card.style.cursor = 'pointer';

      card.addEventListener('click', (e) => {
        // If user clicked an <a> inside, let the browser handle it
        if ((e.target as HTMLElement).closest('a')) return;
        const href = card.dataset.href;
        if (!href) return;
        if (card.dataset.external === 'true') {
          window.open(href, '_blank', 'noopener,noreferrer');
        } else {
          window.location.href = href;
        }
      });

      // Keyboard accessibility
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          card.click();
        }
      });
    });
  }

  // Fetch GitHub star counts from the API
  async function loadGithubStars() {
    const spans = document.querySelectorAll<HTMLElement>('[data-github-stars]');
    await Promise.all(
      [...spans].map(async (span) => {
        const repo = span.dataset.githubStars;
        if (!repo) return;
        try {
          const res = await fetch(`https://api.github.com/repos/${repo}`, {
            headers: { Accept: 'application/vnd.github.v3+json' },
          });
          if (!res.ok) return;
          const data = (await res.json()) as { stargazers_count?: number };
          if (typeof data.stargazers_count === 'number') {
            span.textContent = data.stargazers_count.toLocaleString();
          }
        } catch {
          // Silently ignore — stars are decorative
        }
      })
    );
  }

  initCards();
  loadGithubStars();

  document.addEventListener('astro:after-swap', () => {
    initCards();
    loadGithubStars();
  });
</script>

<style>
  /* ── Page structure ─────────────────────────────────────────────────────── */
  .post {
    padding-top: 0;
  }

  .post-header {
    margin-bottom: 1.5rem;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--global-text-color);
    font-family: var(--font-sans);
    margin-bottom: 0.25rem;
  }

  .post-description {
    color: var(--global-text-color-light);
    font-size: 1rem;
    margin: 0;
  }

  /* ── Projects container ─────────────────────────────────────────────────── */
  .projects a {
    text-decoration: none;
  }

  /* Category headings — right-aligned with divider (matches al-folio) */
  h2.category {
    color: var(--global-divider-color);
    border-bottom: 1px solid var(--global-divider-color);
    padding-top: 0.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    text-align: right;
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    text-transform: lowercase;
  }

  /* Remove underline from category anchor */
  .projects a:has(h2.category) {
    text-decoration: none;
  }

  /* ── Responsive grid ─────────────────────────────────────────────────────── */
  .projects-grid {
    display: flex;
    flex-wrap: wrap;
    margin: 0 -0.5rem;
  }

  .col {
    padding: 0 0.5rem;
    margin-bottom: 1rem;
    flex: 0 0 100%;
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .col {
      flex: 0 0 50%;
      max-width: 50%;
    }
  }

  @media (min-width: 992px) {
    .col {
      flex: 0 0 33.333%;
      max-width: 33.333%;
    }
  }

  /* ── Card ───────────────────────────────────────────────────────────────── */
  .card {
    border: 1px solid var(--global-divider-color);
    border-radius: 4px;
    background-color: var(--global-card-bg-color);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .h-100 {
    height: 100%;
  }

  .hoverable {
    transition: box-shadow 0.25s ease;
  }

  .hoverable:hover {
    box-shadow:
      0 5px 11px 0 rgba(0, 0, 0, 0.18),
      0 4px 15px 0 rgba(0, 0, 0, 0.15);
  }

  .card-img-top {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .card-body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    color: var(--global-text-color);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
    transition: color 0.15s ease;
  }

  .card:hover .card-title {
    color: var(--global-theme-color);
  }

  .card-text {
    color: var(--global-text-color-light);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  /* ── GitHub icon row ─────────────────────────────────────────────────────── */
  .row-icons {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .github-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .github-icon .icon a {
    color: var(--global-text-color);
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
  }

  .github-icon .icon a:hover {
    color: var(--global-theme-color);
  }

  .gh-icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  .stars {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.8rem;
    color: var(--global-text-color-light);
  }
</style>

---
import { getCollection } from 'astro:content';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.importance ?? 999) - (b.data.importance ?? 999)
);
---

<Page title="Projects" description={`Projects by ${site.author.name}`}>
  <h1
    class="text-3xl font-bold mb-8"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    Projects
  </h1>

  {
    projects.length === 0 ? (
      <p style="color: var(--global-text-color-light);">No projects yet.</p>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => {
          const href = project.data.redirect ?? project.data.url ?? `${site.base}/projects/${project.id}/`;
          return (
            <article
              class="project-card rounded-lg overflow-hidden z-depth-1"
              style="background-color: var(--global-card-bg-color); border: 1px solid var(--global-divider-color);"
            >
              {project.data.img && (
                <a href={href} target={project.data.redirect ? '_blank' : undefined} rel={project.data.redirect ? 'noopener noreferrer' : undefined}>
                  <img
                    src={project.data.img}
                    alt={project.data.img_alt ?? project.data.title}
                    loading="lazy"
                    style="width: 100%; height: 180px; object-fit: cover;"
                  />
                </a>
              )}
              <div class="p-4">
                {project.data.category && (
                  <span
                    class="badge-abbr text-xs mb-2 inline-block"
                    style="background-color: var(--global-theme-color); color: var(--global-hover-text-color);"
                  >
                    {project.data.category}
                  </span>
                )}
                <h2 class="text-lg font-semibold mb-1" style="color: var(--global-text-color);">
                  <a
                    href={href}
                    target={project.data.redirect ? '_blank' : undefined}
                    rel={project.data.redirect ? 'noopener noreferrer' : undefined}
                    style="color: var(--global-text-color); text-decoration: none;"
                    class="project-title-link"
                  >
                    {project.data.title}
                  </a>
                </h2>
                {project.data.description && (
                  <p class="text-sm" style="color: var(--global-text-color-light);">
                    {project.data.description}
                  </p>
                )}
                {project.data.github && (
                  <a
                    href={`https://github.com/${project.data.github}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 mt-2 text-xs"
                    style="color: var(--global-theme-color); text-decoration: none;"
                  >
                    GitHub &rarr;
                  </a>
                )}
              </div>
            </article>
          );
        })}
      </div>
    )
  }
</Page>

<style>
  .project-title-link:hover {
    color: var(--global-theme-color) !important;
  }
</style>

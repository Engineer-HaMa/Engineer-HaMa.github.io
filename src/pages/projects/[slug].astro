---
import { getCollection, render } from 'astro:content';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const {
  title,
  description,
  img,
  img_alt,
  url,
  github,
  category,
  redirect,
} = project.data;

// If this project has a redirect, forward immediately (handled at the page level).
if (redirect) {
  return Astro.redirect(redirect);
}

const githubUrl = github ? `https://github.com/${github}` : undefined;
---

<Page title={title} description={description}>
  <article>
    <!-- Page header -->
    <header class="project-header mb-8">
      {category && (
        <span
          class="badge-abbr text-xs mb-3 inline-block"
          style="background-color: var(--global-theme-color); color: var(--global-hover-text-color);"
        >
          {category}
        </span>
      )}

      <h1
        class="text-3xl font-bold mb-3"
        style="color: var(--global-text-color); font-family: var(--font-sans);"
      >
        {title}
      </h1>

      {description && (
        <p
          class="text-lg mb-4"
          style="color: var(--global-text-color-light);"
        >
          {description}
        </p>
      )}

      <!-- External links -->
      {(githubUrl || url) && (
        <div class="flex flex-wrap gap-3 mb-6">
          {githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="project-btn project-btn--primary inline-flex items-center gap-2 px-4 py-2 rounded text-sm font-medium no-underline"
            >
              <!-- GitHub icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              </svg>
              GitHub
            </a>
          )}
          {url && url !== githubUrl && (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="project-btn project-btn--secondary inline-flex items-center gap-2 px-4 py-2 rounded text-sm font-medium no-underline"
            >
              <!-- External link icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
              Website
            </a>
          )}
        </div>
      )}
    </header>

    <!-- Hero image -->
    {img && (
      <div class="project-hero mb-8 rounded-lg overflow-hidden" style="border: 1px solid var(--global-divider-color);">
        <img
          src={img}
          alt={img_alt ?? title}
          loading="eager"
          style="width: 100%; height: auto; max-height: 400px; object-fit: cover; display: block;"
        />
      </div>
    )}

    <!-- Body content -->
    <div class="prose max-w-none" id="project-content">
      <Content />
    </div>

    <!-- Back link -->
    <div class="mt-10 pt-6" style="border-top: 1px solid var(--global-divider-color);">
      <a
        href={`${site.base}/projects/`}
        class="back-link inline-flex items-center gap-1 text-sm font-medium no-underline"
        style="color: var(--global-theme-color);"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6" />
        </svg>
        Projects
      </a>
    </div>
  </article>
</Page>

<!-- Medium zoom for project images -->
<script>
  import mediumZoom from 'medium-zoom';
  function initZoom() {
    mediumZoom('#project-content img:not(.no-zoom)', {
      background: 'rgba(0,0,0,0.7)',
      margin: 24,
    });
  }
  initZoom();
  document.addEventListener('astro:after-swap', initZoom);
</script>

<style>
  .project-btn--primary {
    background-color: var(--global-theme-color);
    color: var(--global-hover-text-color);
    transition: opacity 0.15s ease;
  }
  .project-btn--primary:hover {
    opacity: 0.85;
  }

  .project-btn--secondary {
    background-color: transparent;
    color: var(--global-text-color);
    border: 1px solid var(--global-divider-color);
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .project-btn--secondary:hover {
    border-color: var(--global-theme-color);
    color: var(--global-theme-color);
  }

  .back-link:hover {
    opacity: 0.75;
  }
</style>

---
import { getCollection } from 'astro:content';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';

const all = await getCollection('people');
const current = all
  .filter((p) => p.data.group === 'current')
  .sort((a, b) => (a.data.importance ?? 999) - (b.data.importance ?? 999));
const alumni = all
  .filter((p) => p.data.group === 'alumni')
  .sort((a, b) => (a.data.importance ?? 999) - (b.data.importance ?? 999));
---

<Page title="People" description={`Research group members of ${site.author.name}`}>
  <h1
    class="text-3xl font-bold mb-8"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    People
  </h1>

  {
    current.length > 0 && (
      <section class="mb-10">
        <h2
          class="text-xl font-bold mb-6"
          style="color: var(--global-theme-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.25rem;"
        >
          Current Members
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {current.map((person) => (
            <div class="person-card text-center">
              {person.data.photo ? (
                <img
                  src={person.data.photo}
                  alt={person.data.name}
                  loading="lazy"
                  style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin: 0 auto 0.75rem;"
                />
              ) : (
                <div
                  style="width: 120px; height: 120px; border-radius: 50%; background-color: var(--global-divider-color); margin: 0 auto 0.75rem; display: flex; align-items: center; justify-content: center;"
                >
                  <span style="font-size: 2rem; color: var(--global-text-color-light);">
                    {person.data.name.charAt(0)}
                  </span>
                </div>
              )}

              <h3 class="font-semibold text-sm" style="color: var(--global-text-color);">
                {person.data.website ? (
                  <a
                    href={person.data.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    style="color: var(--global-text-color); text-decoration: none;"
                  >
                    {person.data.name}
                  </a>
                ) : (
                  person.data.name
                )}
              </h3>
              <p class="text-xs mt-0.5" style="color: var(--global-text-color-light);">
                {person.data.role}
              </p>

              {/* Social icons */}
              <div class="flex justify-center gap-2 mt-1">
                {person.data.github && (
                  <a
                    href={`https://github.com/${person.data.github}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs"
                    style="color: var(--global-text-color-light); text-decoration: none;"
                    aria-label="GitHub"
                  >
                    gh
                  </a>
                )}
                {person.data.scholar && (
                  <a
                    href={`https://scholar.google.com/citations?user=${person.data.scholar}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs"
                    style="color: var(--global-text-color-light); text-decoration: none;"
                    aria-label="Google Scholar"
                  >
                    gs
                  </a>
                )}
              </div>

              {person.data.description && (
                <p class="text-xs mt-1" style="color: var(--global-text-color-light);">
                  {person.data.description}
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    alumni.length > 0 && (
      <section class="mb-10">
        <h2
          class="text-xl font-bold mb-6"
          style="color: var(--global-theme-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.25rem;"
        >
          Alumni
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
          {alumni.map((person) => (
            <div class="flex items-center gap-3">
              {person.data.photo && (
                <img
                  src={person.data.photo}
                  alt={person.data.name}
                  loading="lazy"
                  style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
                />
              )}
              <div>
                <p class="font-semibold text-sm" style="color: var(--global-text-color);">
                  {person.data.website ? (
                    <a
                      href={person.data.website}
                      target="_blank"
                      rel="noopener noreferrer"
                      style="color: var(--global-text-color); text-decoration: none;"
                    >
                      {person.data.name}
                    </a>
                  ) : (
                    person.data.name
                  )}
                </p>
                <p class="text-xs" style="color: var(--global-text-color-light);">
                  {person.data.role}
                </p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    all.length === 0 && (
      <p style="color: var(--global-text-color-light);">No people entries yet.</p>
    )
  }
</Page>

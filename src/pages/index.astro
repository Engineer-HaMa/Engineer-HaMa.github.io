---
import { getCollection, render } from 'astro:content';
import { site } from '@config/site';
import Base from '@layouts/Base.astro';
import SocialLinks from '@components/SocialLinks.astro';
import ProfilePhoto from '@components/about/ProfilePhoto.astro';
import AboutContent from '../data/about.mdx';
import { parseBibtex, getAuthors, getVenue, getTitle, getYear, getBoolField } from '@utils/bibtex';
import bibRaw from '../data/papers.bib?raw';

// Announcements
const allAnnouncements = site.announcements.enabled
  ? (await getCollection('announcements'))
      .filter((e) => !e.data.hidden)
      .sort((a, b) => {
        if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
        return b.data.date.getTime() - a.data.date.getTime();
      })
      .slice(0, site.announcements.limit)
  : [];

// Latest posts
const allPosts = site.latestPosts.enabled
  ? (await getCollection('posts'))
      .filter((p) => !p.data.hidden)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .slice(0, site.latestPosts.limit)
  : [];

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Selected publications
const selectedPapers = site.selectedPapers.enabled
  ? parseBibtex(bibRaw).filter((e) => getBoolField(e, 'selected'))
  : [];

// Pre-render announcement content in frontmatter (async in JSX map is not supported)
const renderedAnnouncements = await Promise.all(
  allAnnouncements.map(async (item) => ({ item, rendered: await render(item) }))
);
---

<Base>
  <div class="page-container py-8">
    <!-- Profile section -->
    <div class="about-header mb-8 clearfix">
      <ProfilePhoto align="right" />

      <div>
        <h1
          class="text-3xl font-bold mb-1"
          style="color: var(--global-text-color); font-family: var(--font-sans);"
        >
          {site.author.name}
        </h1>

        {
          site.author.subtitle && (
            <p class="text-base mb-3" style="color: var(--global-text-color-light);" set:html={site.author.subtitle} />
          )
        }

        <SocialLinks class="mb-3" />

        {
          site.author.moreInfo && (
            <div
              class="text-sm"
              style="color: var(--global-text-color-light);"
              set:html={site.author.moreInfo}
            />
          )
        }
      </div>
    </div>

    <!-- Bio -->
    <div class="prose max-w-none mb-10">
      <AboutContent />
    </div>

    <!-- Announcements -->
    {
      site.announcements.enabled && allAnnouncements.length > 0 && (
        <section class="mb-10">
          <h2
            class="text-xl font-bold mb-3"
            style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.5rem;"
          >
            News
          </h2>
          <div
            class={site.announcements.scrollable ? 'scrollable-list' : ''}
          >
            <table style="width: 100%; border-collapse: collapse;">
              <tbody>
                {renderedAnnouncements.map(({ item, rendered: { Content } }) => (
                  <tr style="border-bottom: 1px solid var(--global-divider-color);">
                    <td
                      style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;"
                    >
                      {formatDate(item.data.date)}
                    </td>
                    <td style="padding: 0.5rem 0; font-size: 0.9rem; color: var(--global-text-color);">
                      <Content />
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )
    }

    <!-- Latest posts -->
    {
      site.latestPosts.enabled && allPosts.length > 0 && (
        <section class="mb-10">
          <h2
            class="text-xl font-bold mb-3"
            style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.5rem;"
          >
            Latest Posts
          </h2>
          <div class={site.latestPosts.scrollable ? 'scrollable-list' : ''}>
            <table style="width: 100%; border-collapse: collapse;">
              <tbody>
                {allPosts.map((post) => (
                  <tr style="border-bottom: 1px solid var(--global-divider-color);">
                    <td
                      style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;"
                    >
                      {formatDate(post.data.date)}
                    </td>
                    <td style="padding: 0.5rem 0; font-size: 0.9rem;">
                      <a
                        href={`${site.base}/blog/${post.id}/`}
                        style="color: var(--global-theme-color); text-decoration: none;"
                      >
                        {post.data.title}
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )
    }
    <!-- Selected publications -->
    {
      site.selectedPapers.enabled && selectedPapers.length > 0 && (
        <section class="mb-10">
          <h2
            class="text-xl font-bold mb-3"
            style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.5rem;"
          >
            Selected Publications
          </h2>
          <ol class="list-none p-0 m-0">
            {selectedPapers.map((entry) => {
              const title = getTitle(entry);
              const authors = getAuthors(entry);
              const venue = getVenue(entry);
              const year = getYear(entry);
              const abbr = entry.fields.abbr;
              const url = entry.fields.html ?? (entry.fields.doi ? `https://doi.org/${entry.fields.doi}` : '');
              const award = entry.fields.award;
              return (
                <li class="mb-4 text-sm" style="line-height: 1.6;">
                  {abbr && (
                    <span
                      class="badge-abbr mr-2"
                      style="background-color: var(--global-theme-color); color: var(--global-hover-text-color); font-size: 0.65rem;"
                    >
                      {abbr}
                    </span>
                  )}
                  {url ? (
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      style="color: var(--global-text-color); font-weight: 600; text-decoration: none;"
                      class="hover-theme-color"
                    >
                      {title}
                    </a>
                  ) : (
                    <strong style="color: var(--global-text-color);">{title}</strong>
                  )}
                  <br />
                  <span style="color: var(--global-text-color-light);">{authors}</span>
                  {(venue || year) && (
                    <>
                      {' · '}
                      <em style="color: var(--global-text-color-light);">
                        {venue}
                        {venue && year ? ', ' : ''}
                        {year || ''}
                      </em>
                    </>
                  )}
                  {award && (
                    <span
                      class="badge-abbr ml-2"
                      style="background-color: #f59e0b; color: #fff; font-size: 0.6rem;"
                    >
                      {entry.fields.award_name ?? '🏆'}
                    </span>
                  )}
                </li>
              );
            })}
          </ol>
          <p class="text-sm mt-2">
            <a
              href={`${site.base}/publications/`}
              style="color: var(--global-theme-color); text-decoration: none;"
            >
              Full publication list &rarr;
            </a>
          </p>
        </section>
      )
    }
  </div>
</Base>

<style>
  .clearfix::after {
    content: '';
    display: table;
    clear: both;
  }
</style>

---
import ProfilePhoto from '@components/about/ProfilePhoto.astro';
import EmailCopy from '@components/EmailCopy.astro';
import SocialLinks from '@components/SocialLinks.astro';
import { site } from '@config/site';
import Base from '@layouts/Base.astro';
import { getAuthors, getBoolField, getTitle, getVenue, getYear, parseBibtex } from '@utils/bibtex';
import { getCollection, render } from 'astro:content';

import AboutContent from '../data/about.mdx';
import bibRaw from '../data/papers.bib?raw';

// Announcements
const allAnnouncements = site.announcements.enabled
  ? (await getCollection('announcements'))
      .filter((e) => !e.data.hidden)
      .sort((a, b) => {
        if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
        return b.data.date.getTime() - a.data.date.getTime();
      })
      .slice(0, site.announcements.limit)
  : [];

// Latest posts
const allPosts = site.latestPosts.enabled
  ? (await getCollection('posts'))
      .filter((p) => !p.data.hidden)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .slice(0, site.latestPosts.limit)
  : [];

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Experience — research positions, rendered as its own listing section.
const experience: Array<{
  period: string;
  role: string;
  org: string;
  href?: string;
}> = [
  {
    period: '2026 – present',
    role: 'Graduate Research Assistant',
    org: 'CASYS Lab, KAIST',
    href: 'https://casyslab.kaist.ac.kr/',
  },
];

// Education timeline — rendered as its own listing section (like latest posts).
const education: Array<{
  period: string;
  degree: string;
  org: string;
  detail?: string;
  href?: string;
  advisor?: string;
  advisorHref?: string;
}> = [
  {
    period: '2026 – present',
    degree: 'M.S., School of Computing',
    org: 'KAIST',
    detail: 'CASYS Lab',
    href: 'https://casyslab.kaist.ac.kr/',
    advisor: 'Youngjin Kwon',
    advisorHref: 'https://sites.google.com/view/yjkwon/home',
  },
  {
    period: '2020 – 2025',
    degree: 'B.S., School of Computing',
    org: 'KAIST',
  },
];

// Selected publications
const selectedPapers = site.selectedPapers.enabled
  ? parseBibtex(bibRaw).filter((e) => getBoolField(e, 'selected'))
  : [];

// Pre-render announcement content
const renderedAnnouncements = await Promise.all(
  allAnnouncements.map(async (item) => ({ item, rendered: await render(item) })),
);
---

<Base isHome={true}>
  <div class="post page-container py-8">
    <article>
      <!-- Profile photo floats right, top-aligned with the name header -->
      <ProfilePhoto align="right" />

      <header class="post-header">
        <h1
          class="post-title"
          style="font-family: var(--font-sans); color: var(--global-text-color);"
        >
          {(site.title as string) === 'blank' ? site.author.name : site.title}
        </h1>
        {
          site.author.subtitle && (
            <p
              class="desc"
              style="color: var(--global-text-color-light);"
              set:html={site.author.subtitle}
            />
          )
        }
      </header>

      <!-- Bio content from about.mdx -->
      <div class="prose about-bio max-w-none">
        <AboutContent />
      </div>

      <style>
        /* The theme's global reset strips paragraph spacing on the about `prose`
           — restore a clean rhythm for the short bio. */
        .about-bio :global(p) {
          margin-bottom: 0.85rem;
        }
      </style>

      <!-- Social icons -->
      {
        site.socials && (
          <div class="social mt-6">
            <div class="contact-icons" style="display: flex; align-items: center; gap: 0.5rem;">
              <EmailCopy />
              <SocialLinks />
            </div>
          </div>
        )
      }

      <!-- Clear the floated photo so the listing sections sit full-width below it -->
      <div style="clear: both;"></div>

      <!-- Publications -->
      <section class="mt-8">
        <h2
          style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.3rem;"
        >
          publications
        </h2>
        <p style="color: var(--global-text-color-light); font-size: 0.9rem; margin-top: 0.75rem;">
          Coming soon.
        </p>
      </section>

      <!-- Experience -->
      {
        experience.length > 0 && (
          <section class="mt-8">
            <h2 style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.3rem;">
              experience
            </h2>
            <table class="listing-table" style="width: 100%; border-collapse: collapse;">
              <tbody>
                {experience.map((e) => (
                  <tr style="border-bottom: 1px solid var(--global-divider-color);">
                    <td style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;">
                      {e.period}
                    </td>
                    <td style="padding: 0.5rem 0; font-size: 0.9rem; color: var(--global-text-color);">
                      {e.role}
                      {' · '}
                      {e.href ? (
                        <a
                          href={e.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          style="color: var(--global-theme-color); text-decoration: none;"
                        >
                          {e.org}
                        </a>
                      ) : (
                        e.org
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        )
      }

      <!-- Education -->
      {
        education.length > 0 && (
          <section class="mt-8">
            <h2 style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.3rem;">
              education
            </h2>
            <table class="listing-table" style="width: 100%; border-collapse: collapse;">
              <tbody>
                {education.map((e) => (
                  <tr style="border-bottom: 1px solid var(--global-divider-color);">
                    <td style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;">
                      {e.period}
                    </td>
                    <td style="padding: 0.5rem 0; font-size: 0.9rem; color: var(--global-text-color);">
                      {e.degree}, {e.org}
                      {e.detail &&
                        (e.href ? (
                          <>
                            {' · '}
                            <a
                              href={e.href}
                              target="_blank"
                              rel="noopener noreferrer"
                              style="color: var(--global-theme-color); text-decoration: none;"
                            >
                              {e.detail}
                            </a>
                          </>
                        ) : (
                          <>{` · ${e.detail}`}</>
                        ))}
                      {e.advisor && (
                        <div style="margin-top: 0.15rem; font-size: 0.8rem; color: var(--global-text-color-light);">
                          Advised by{' '}
                          {e.advisorHref ? (
                            <a
                              href={e.advisorHref}
                              target="_blank"
                              rel="noopener noreferrer"
                              style="color: var(--global-theme-color); text-decoration: none;"
                            >
                              {e.advisor}
                            </a>
                          ) : (
                            e.advisor
                          )}
                        </div>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        )
      }

      <!-- Announcements / News -->
      {
        site.announcements.enabled && allAnnouncements.length > 0 && (
          <section class="mt-8">
            <h2 style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.3rem;">
              <a href={`${site.base}/news/`} style="color: inherit; text-decoration: none;">
                news
              </a>
            </h2>
            <div class={site.announcements.scrollable ? 'scrollable-list' : ''}>
              <table class="listing-table" style="width: 100%; border-collapse: collapse;">
                <tbody>
                  {renderedAnnouncements.map(({ item, rendered: { Content } }) => (
                    <tr style="border-bottom: 1px solid var(--global-divider-color);">
                      <td style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;">
                        {formatDate(item.data.date)}
                      </td>
                      <td style="padding: 0.5rem 0; font-size: 0.9rem; color: var(--global-text-color);">
                        <Content />
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )
      }

      <!-- Latest posts -->
      {
        site.latestPosts.enabled && allPosts.length > 0 && (
          <section class="mt-8">
            <h2 style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.3rem;">
              <a href={`${site.base}/blog/`} style="color: inherit; text-decoration: none;">
                latest posts
              </a>
            </h2>
            <div class={site.latestPosts.scrollable ? 'scrollable-list' : ''}>
              <table class="listing-table" style="width: 100%; border-collapse: collapse;">
                <tbody>
                  {allPosts.map((post) => (
                    <tr style="border-bottom: 1px solid var(--global-divider-color);">
                      <td style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;">
                        {formatDate(post.data.date)}
                      </td>
                      <td style="padding: 0.5rem 0; font-size: 0.9rem;">
                        <a
                          href={`${site.base}/blog/${post.id}/`}
                          style="color: var(--global-theme-color); text-decoration: none;"
                        >
                          {post.data.title}
                        </a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )
      }

      <!-- Selected publications -->
      {
        site.selectedPapers.enabled && selectedPapers.length > 0 && (
          <section class="mt-8">
            <h2 style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.3rem;">
              <a href={`${site.base}/publications/`} style="color: inherit; text-decoration: none;">
                selected publications
              </a>
            </h2>
            <ol class="m-0 list-none p-0">
              {selectedPapers.map((entry) => {
                const title = getTitle(entry);
                const authors = getAuthors(entry);
                const venue = getVenue(entry);
                const year = getYear(entry);
                const abbr = entry.fields.abbr;
                const url =
                  entry.fields.html ??
                  (entry.fields.doi ? `https://doi.org/${entry.fields.doi}` : '');
                const award = entry.fields.award;
                return (
                  <li class="mb-4 text-sm" style="line-height: 1.6;">
                    {abbr && <span class="badge-abbr mr-2">{abbr}</span>}
                    {url ? (
                      <a
                        href={url}
                        target="_blank"
                        rel="noopener noreferrer"
                        style="color: var(--global-text-color); font-weight: 600; text-decoration: none;"
                      >
                        {title}
                      </a>
                    ) : (
                      <strong style="color: var(--global-text-color);">{title}</strong>
                    )}
                    <br />
                    <span style="color: var(--global-text-color-light);">{authors}</span>
                    {(venue || year) && (
                      <>
                        {' · '}
                        <em style="color: var(--global-text-color-light);">
                          {venue}
                          {venue && year ? ', ' : ''}
                          {year || ''}
                        </em>
                      </>
                    )}
                    {award && (
                      <span class="badge-abbr ml-2" style="background-color: #f59e0b;">
                        {entry.fields.award_name ?? '🏆'}
                      </span>
                    )}
                  </li>
                );
              })}
            </ol>
            <p class="mt-2 text-sm">
              <a
                href={`${site.base}/publications/`}
                style="color: var(--global-theme-color); text-decoration: none;"
              >
                Full publication list &rarr;
              </a>
            </p>
          </section>
        )
      }
    </article>
  </div>
</Base>

<style>
  .post-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .desc {
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  /* Tighten the header block now that the photo floats alongside the name. */
  .post-header {
    margin-bottom: 1rem;
  }
  /* Fix the date/period column to a shared width so the body-text column
     lines up across the experience and education listings. */
  .listing-table td:first-child {
    width: 8rem;
  }
</style>

---
import { getCollection, render } from 'astro:content';
import { site } from '@config/site';
import Base from '@layouts/Base.astro';
import SocialLinks from '@components/SocialLinks.astro';
import ProfilePhoto from '@components/about/ProfilePhoto.astro';
import AboutContent from '../data/about.mdx';

// Announcements
const allAnnouncements = site.announcements.enabled
  ? (await getCollection('announcements'))
      .filter((e) => !e.data.hidden)
      .sort((a, b) => {
        if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
        return b.data.date.getTime() - a.data.date.getTime();
      })
      .slice(0, site.announcements.limit)
  : [];

// Latest posts
const allPosts = site.latestPosts.enabled
  ? (await getCollection('posts'))
      .filter((p) => !p.data.hidden)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .slice(0, site.latestPosts.limit)
  : [];

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Pre-render announcement content in frontmatter (async in JSX map is not supported)
const renderedAnnouncements = await Promise.all(
  allAnnouncements.map(async (item) => ({ item, rendered: await render(item) }))
);
---

<Base>
  <div class="page-container py-8">
    <!-- Profile section -->
    <div class="about-header mb-8 clearfix">
      <ProfilePhoto align="right" />

      <div>
        <h1
          class="text-3xl font-bold mb-1"
          style="color: var(--global-text-color); font-family: var(--font-sans);"
        >
          {site.author.name}
        </h1>

        {
          site.author.subtitle && (
            <p class="text-base mb-3" style="color: var(--global-text-color-light);" set:html={site.author.subtitle} />
          )
        }

        <SocialLinks class="mb-3" />

        {
          site.author.moreInfo && (
            <div
              class="text-sm"
              style="color: var(--global-text-color-light);"
              set:html={site.author.moreInfo}
            />
          )
        }
      </div>
    </div>

    <!-- Bio -->
    <div class="prose max-w-none mb-10">
      <AboutContent />
    </div>

    <!-- Announcements -->
    {
      site.announcements.enabled && allAnnouncements.length > 0 && (
        <section class="mb-10">
          <h2
            class="text-xl font-bold mb-3"
            style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.5rem;"
          >
            News
          </h2>
          <div
            class={site.announcements.scrollable ? 'scrollable-list' : ''}
          >
            <table style="width: 100%; border-collapse: collapse;">
              <tbody>
                {renderedAnnouncements.map(({ item, rendered: { Content } }) => (
                  <tr style="border-bottom: 1px solid var(--global-divider-color);">
                    <td
                      style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;"
                    >
                      {formatDate(item.data.date)}
                    </td>
                    <td style="padding: 0.5rem 0; font-size: 0.9rem; color: var(--global-text-color);">
                      <Content />
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )
    }

    <!-- Latest posts -->
    {
      site.latestPosts.enabled && allPosts.length > 0 && (
        <section class="mb-10">
          <h2
            class="text-xl font-bold mb-3"
            style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.5rem;"
          >
            Latest Posts
          </h2>
          <div class={site.latestPosts.scrollable ? 'scrollable-list' : ''}>
            <table style="width: 100%; border-collapse: collapse;">
              <tbody>
                {allPosts.map((post) => (
                  <tr style="border-bottom: 1px solid var(--global-divider-color);">
                    <td
                      style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;"
                    >
                      {formatDate(post.data.date)}
                    </td>
                    <td style="padding: 0.5rem 0; font-size: 0.9rem;">
                      <a
                        href={`${site.base}/blog/${post.id}/`}
                        style="color: var(--global-theme-color); text-decoration: none;"
                      >
                        {post.data.title}
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )
    }
  </div>
</Base>

<style>
  .clearfix::after {
    content: '';
    display: table;
    clear: both;
  }
</style>

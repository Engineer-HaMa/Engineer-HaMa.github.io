---
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { parseBibtex } from '@utils/bibtex';
import BibSearch from '@components/publications/BibSearch.tsx';
import bibRaw from '../../data/papers.bib?raw';

const entries = parseBibtex(bibRaw).sort((a, b) => {
  const yearA = parseInt(a.fields.year ?? '0', 10);
  const yearB = parseInt(b.fields.year ?? '0', 10);
  return yearB - yearA;
});

const showAltmetric = site.publications.badges.altmetric;
const showDimensions = site.publications.badges.dimensions;
---

<Page title="Publications" description={`Publications by ${site.author.name}`}>
  <h1
    class="text-3xl font-bold mb-8"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    Publications
  </h1>

  <BibSearch client:load entries={entries} />
</Page>

{showAltmetric && (
  <script is:inline src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js"></script>
)}

{showDimensions && (
  <script is:inline async src="https://badge.dimensions.ai/badge.js"></script>
)}

<style>
  .pub-title:hover {
    color: var(--global-theme-color) !important;
  }
</style>

---
import PostMeta from '@components/blog/PostMeta.astro';
import RelatedPosts from '@components/blog/RelatedPosts.astro';
import Giscus from '@components/Giscus.astro';
import Newsletter from '@components/Newsletter.astro';
import ReadingProgress from '@components/ReadingProgress.astro';
import TOC from '@components/TOC.astro';
import { site } from '@config/site';
import { relatedPosts } from '@utils/posts';
import { readingTime as calcReadingTime } from '@utils/reading-time';
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

import Base from './Base.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  headings?: MarkdownHeading[];
}

const { post, headings = [] } = Astro.props;
const {
  title, description, date, lastmod, tags = [], categories = [],
  robots, draft = false,
  mermaid = false, chart_js = false, echarts = false, vega = false, plotly = false,
  pseudocode = false, typograms = false, tikzjax = false, map = false,
  img_comparison = false, code_diff = false, gallery = false, disqus = false,
} = post.data;

const effectiveRobots = draft ? 'noindex, nofollow' : robots;

const lastmodFormatted = lastmod
  ? lastmod.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const rt = post.body ? calcReadingTime(post.body, site.blog.wordsPerMinute) : 1;

// Related posts (if post has tags)
const allPosts = await getCollection('posts');
const related = post.data.relatedPosts ? relatedPosts(post, allPosts) : [];

// JSON-LD BlogPosting schema
const canonicalURL = new URL(`${site.base}/blog/${post.id}/`, site.url).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  ...(description ? { description } : {}),
  datePublished: date.toISOString(),
  ...(lastmod ? { dateModified: lastmod.toISOString() } : {}),
  url: canonicalURL,
  author: {
    '@type': 'Person',
    name: site.author.name,
    url: site.url,
  },
  ...(post.data.image ? { image: new URL(post.data.image, site.url).toString() } : {}),
};
---

<Base title={title} description={description} robots={effectiveRobots}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  {site.features.progressBar && <ReadingProgress />}

  <div class="page-container py-8">
    <div class="flex gap-8">
      <!-- TOC sidebar (desktop only) -->
      {
        headings.length > 0 && (
          <aside class="hidden lg:block w-52 flex-shrink-0">
            <TOC headings={headings} />
          </aside>
        )
      }

      <!-- Post content -->
      <article class="flex-1 min-w-0">
        <!-- Header -->
        <header class="post-header">
          <h1 class="post-title" style="margin-bottom: 0.75rem;">
            {title}
          </h1>

          <PostMeta date={date} tags={tags} categories={categories} readingTime={rt} />
          {lastmodFormatted && (
            <p class="post-lastmod" style="font-size: 0.8rem; color: var(--global-text-color-light); margin-top: 0.25rem;">
              Updated <time datetime={lastmod!.toISOString()}>{lastmodFormatted}</time>
            </p>
          )}
        </header>

        <!-- Body -->
        <div class="prose max-w-none" id="post-content">
          <slot />
        </div>

        <!-- Newsletter CTA (shown after post body when feature is enabled) -->
        {site.features.newsletter && <Newsletter />}

        <!-- Related posts -->
        {related.length > 0 && <RelatedPosts posts={related} />}

        <!-- Comments -->
        {site.giscus.enabled && <Giscus />}
      </article>
    </div>
  </div>
</Base>

<!-- Code copy button (text-label approach, no innerHTML) -->
<script>
  function addCopyButtons() {
    const blocks = document.querySelectorAll('#post-content pre');
    blocks.forEach((pre) => {
      if (pre.querySelector('.copy-btn')) return;
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.textContent = 'copy';
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (!code) return;
        await navigator.clipboard.writeText(code.innerText);
        btn.textContent = 'copied!';
        setTimeout(() => {
          btn.textContent = 'copy';
        }, 2000);
      });
      (pre as HTMLElement).style.position = 'relative';
      pre.appendChild(btn);
    });
  }
  addCopyButtons();
  document.addEventListener('astro:after-swap', addCopyButtons);
</script>

<!-- Medium zoom for post images -->
<script>
  import mediumZoom from 'medium-zoom';
  function initZoom() {
    mediumZoom('#post-content img:not(.no-zoom)', {
      background: 'rgba(0,0,0,0.7)',
      margin: 24,
    });
  }
  initZoom();
  document.addEventListener('astro:after-swap', initZoom);
</script>

<!-- ── Per-post CDN widgets ──────────────────────────────────────────────── -->

{mermaid && (
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    mermaid.initialize({ startOnLoad: true, theme: document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default' });
    document.querySelectorAll('pre.language-mermaid code, code.language-mermaid').forEach((el) => {
      const pre = el.closest('pre') ?? el;
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = el.textContent ?? '';
      pre.replaceWith(div);
    });
    mermaid.run();
  </script>
)}

{chart_js && (
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
)}

{echarts && (
  <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js" defer></script>
)}

{vega && (
  <>
    <script src="https://cdn.jsdelivr.net/npm/vega@5" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/vega-lite@5" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/vega-embed@6" defer></script>
  </>
)}

{plotly && (
  <script src="https://cdn.jsdelivr.net/npm/plotly.js@2/dist/plotly.min.js" defer></script>
)}

{pseudocode && (
  <>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pseudocode@2.4.1/build/pseudocode.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/pseudocode@2.4.1/build/pseudocode.min.js" defer></script>
  </>
)}

{typograms && (
  <script src="/assets/js/typograms.js" type="module"></script>
)}

{tikzjax && (
  <>
    <link rel="stylesheet" href="https://tikzjax.com/v1/fonts.css" />
    <script src="https://tikzjax.com/v1/tikzjax.js"></script>
  </>
)}

{map && (
  <>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
  </>
)}

{img_comparison && (
  <>
    <script type="module" src="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/index.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/styles.css" />
  </>
)}

{code_diff && (
  <>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/diff2html/bundles/css/diff2html.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/diff2html/bundles/js/diff2html-ui.min.js" defer></script>
  </>
)}

{gallery && (
  <>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.css" />
    <script type="module">{`
      import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe-lightbox.esm.js';
      const lightbox = new PhotoSwipeLightbox({
        gallery: '#post-content',
        children: 'a[data-pswp-width]',
        pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.esm.js'),
      });
      lightbox.init();
    `}</script>
  </>
)}

{disqus && (
  <>
    <div id="disqus_thread" class="mt-8 pt-6" style="border-top: 1px solid var(--global-divider-color);"></div>
    <script is:inline define:vars={{ disqusUrl: Astro.url.href, disqusId: post.id, disqusShortname: site.comments.disqusShortname }}>
      var disqus_config = function () {
        this.page.url = disqusUrl;
        this.page.identifier = disqusId;
      };
      (function() {
        var d = document, s = d.createElement('script');
        s.src = `https://${disqusShortname}.disqus.com/embed.js`;
        s.setAttribute('data-timestamp', +new Date());
        (d.head || d.body).appendChild(s);
      })();
    </script>
  </>
)}

<style>
  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s;
    font-size: 0.7rem;
    font-family: var(--font-mono, monospace);
    background-color: var(--global-card-bg-color, #f5f5f5);
    color: var(--global-text-color-light, #888);
    line-height: 1.5;
  }
  pre:hover .copy-btn {
    opacity: 1;
  }
  .copy-btn:hover {
    background-color: var(--global-theme-color);
    color: var(--global-hover-text-color, #fff);
  }
</style>

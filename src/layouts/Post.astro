---
import PostMeta from '@components/blog/PostMeta.astro';
import RelatedPosts from '@components/blog/RelatedPosts.astro';
import SocialShare from '@components/blog/SocialShare.astro';
import Giscus from '@components/Giscus.astro';
import Newsletter from '@components/Newsletter.astro';
import ReadingProgress from '@components/ReadingProgress.astro';
import TOC from '@components/TOC.astro';
import { site } from '@config/site';
import { relatedPosts } from '@utils/posts';
import { readingTime as calcReadingTime } from '@utils/reading-time';
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

import Base from './Base.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  headings?: MarkdownHeading[];
}

const { post, headings = [] } = Astro.props;
const {
  title, description, date, lastmod, tags = [], categories = [],
  robots, draft = false,
  mermaid = false, chart_js = false, echarts = false, vega = false, plotly = false,
  pseudocode = false, typograms = false, tikzjax = false, map = false,
  img_comparison = false, code_diff = false, gallery = false, disqus = false,
} = post.data;

const effectiveRobots = draft ? 'noindex, nofollow' : robots;

const lastmodFormatted = lastmod
  ? lastmod.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const rt = post.body ? calcReadingTime(post.body, site.blog.wordsPerMinute) : 1;

// Related posts (if post has tags)
const allPosts = await getCollection('posts');
const related = post.data.relatedPosts ? relatedPosts(post, allPosts) : [];

// JSON-LD BlogPosting schema
const canonicalURL = new URL(`${site.base}/blog/${post.id}/`, site.url).toString();

// Generated OG image (falls back to static og.image if post has its own cover)
const ogImagePath = post.data.image
  ? new URL(post.data.image, site.url).toString()
  : new URL(`${site.base}/og/blog/${post.id}.png`, site.url).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  ...(description ? { description } : {}),
  datePublished: date.toISOString(),
  ...(lastmod ? { dateModified: lastmod.toISOString() } : {}),
  url: canonicalURL,
  author: {
    '@type': 'Person',
    name: site.author.name,
    url: site.url,
  },
  image: ogImagePath,
};
---

<Base title={title} description={description} robots={effectiveRobots} image={ogImagePath}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          {
            '@type': 'ListItem',
            position: 1,
            name: 'Blog',
            item: new URL(`${site.base}/blog/`, site.url).toString(),
          },
          { '@type': 'ListItem', position: 2, name: title, item: canonicalURL },
        ],
      })}
    />
  </Fragment>
  {site.features.progressBar && <ReadingProgress />}

  <div class="page-container py-8">
    <div class="flex gap-8">
      <!-- TOC sidebar (desktop only) -->
      {
        headings.length > 0 && (
          <aside class="hidden lg:block w-52 flex-shrink-0">
            <TOC headings={headings} />
          </aside>
        )
      }

      <!-- Post content -->
      <article class="flex-1 min-w-0">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="breadcrumb-nav">
          <a href={`${site.base}/blog/`} class="breadcrumb-link">← Blog</a>
        </nav>

        <!-- Header -->
        <header class="post-header">
          <h1 class="post-title" style="margin-bottom: 0.75rem;">
            {title}
          </h1>

          <PostMeta date={date} tags={tags} categories={categories} readingTime={rt} />
          {lastmodFormatted && (
            <p class="post-lastmod" style="font-size: 0.8rem; color: var(--global-text-color-light); margin-top: 0.25rem;">
              Updated <time datetime={lastmod!.toISOString()}>{lastmodFormatted}</time>
            </p>
          )}
        </header>

        <!-- Body -->
        <div class="prose max-w-none" id="post-content">
          <slot />
        </div>

        <!-- Newsletter CTA (shown after post body when feature is enabled) -->
        {site.features.newsletter && <Newsletter />}

        <!-- Social sharing links -->
        {
          site.features.socialShare && (
            <SocialShare title={title} url={canonicalURL} description={description} />
          )
        }

        <!-- Related posts -->
        {related.length > 0 && <RelatedPosts posts={related} />}

        <!-- Comments -->
        {site.giscus.enabled && <Giscus />}
      </article>
    </div>
  </div>
</Base>

<!-- Code copy button (text-label approach, no innerHTML) -->
<script>
  function addCopyButtons() {
    const blocks = document.querySelectorAll('#post-content pre');
    blocks.forEach((pre) => {
      if (pre.querySelector('.copy-btn')) return;
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.textContent = 'copy';
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (!code) return;
        await navigator.clipboard.writeText(code.innerText);
        btn.textContent = 'copied!';
        setTimeout(() => {
          btn.textContent = 'copy';
        }, 2000);
      });
      (pre as HTMLElement).style.position = 'relative';
      pre.appendChild(btn);
    });
  }
  addCopyButtons();
  document.addEventListener('astro:after-swap', addCopyButtons);
</script>

<!-- Medium zoom for post images -->
<script>
  import mediumZoom from 'medium-zoom';
  let zoom: ReturnType<typeof mediumZoom> | null = null;

  function initZoom() {
    zoom?.detach();
    zoom = null;

    // All images in post content are zoomable by default.
    // Add class="no-zoom" (or use <Figure zoomable={false} />) to opt out.
    const imgs = document.querySelectorAll<HTMLImageElement>('#post-content img:not(.no-zoom)');
    if (imgs.length === 0) return;

    zoom = mediumZoom(imgs, { background: 'rgba(0,0,0,0.7)', margin: 24 });

    // Failsafe: medium-zoom's close() exits early when isAnimating === true.
    // isAnimating resets only when transitionend fires on the zoomed clone.
    // If the CSS transition doesn't start (transform set synchronously in the
    // same frame the clone is inserted), transitionend never fires and the zoom
    // gets permanently stuck open. Fix: after the open event, if the library's
    // own medium-zoom:opened event (fired inside _handleOpenEnd after the real
    // transitionend) hasn't fired within 400 ms, dispatch a synthetic
    // transitionend on the clone to unblock close().
    zoom.on('open', (event: Event) => {
      const original = event.target as HTMLElement;
      let resolved = false;

      const markResolved = () => { resolved = true; };
      original.addEventListener('medium-zoom:opened', markResolved, { once: true });

      setTimeout(() => {
        original.removeEventListener('medium-zoom:opened', markResolved);
        if (resolved) return;
        const clone = document.querySelector<HTMLElement>('.medium-zoom-image--opened');
        clone?.dispatchEvent(
          new TransitionEvent('transitionend', {
            bubbles: false,
            propertyName: 'transform',
            elapsedTime: 0.3,
          }),
        );
      }, 400);
    });
  }

  initZoom();
  document.addEventListener('astro:after-swap', initZoom);
</script>

<!-- ── Per-post CDN widgets ──────────────────────────────────────────────── -->

{mermaid && (
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    mermaid.initialize({ startOnLoad: true, theme: document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default' });
    document.querySelectorAll('pre.language-mermaid code, code.language-mermaid').forEach((el) => {
      const pre = el.closest('pre') ?? el;
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = el.textContent ?? '';
      pre.replaceWith(div);
    });
    mermaid.run();
  </script>
)}

{chart_js && (
  <script
    src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"
    integrity="sha384-jb8JQMbMoBUzgWatfe6COACi2ljcDdZQ2OxczGA3bGNeWe+6DChMTBJemed7ZnvJ"
    crossorigin="anonymous"
    defer></script>
)}

{echarts && (
  <script
    src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"
    integrity="sha384-pPi0zxBAoDu6+JXW/C68UZLvBUUtU+7zonhif43rqj7pxsGyqyqzcian2Rj37Rss"
    crossorigin="anonymous"
    defer></script>
)}

{vega && (
  <>
    <script
      src="https://cdn.jsdelivr.net/npm/vega@5"
      integrity="sha384-NMXhl2TbCXxcN7o4ROC56Funm78m4AylL8gMg/7Kn4YU+wrm23K9l7cY8lDRXQ9d"
      crossorigin="anonymous"
      defer></script>
    <script
      src="https://cdn.jsdelivr.net/npm/vega-lite@5"
      integrity="sha384-D9LYH0esGjcxQJsBuxOuXtCDJGXRWW1+KhluzWPqi0rLJmiR/ygPChefaD+rFFDQ"
      crossorigin="anonymous"
      defer></script>
    <script
      src="https://cdn.jsdelivr.net/npm/vega-embed@6"
      integrity="sha384-M+Ax7e/WFJpxSOF09HzI+Sj4wg9ottVd/uxmV2ItGGh02fLH28t2FAOJx3TJBap5"
      crossorigin="anonymous"
      defer></script>
  </>
)}

{plotly && (
  <script
    src="https://cdn.jsdelivr.net/npm/plotly.js@2/dist/plotly.min.js"
    integrity="sha384-MqL7Cy3itNqCI1Wlc926K0XhyRKJ/NMqTaytIIEB+QIdInOploxqRIHRKLlhPykM"
    crossorigin="anonymous"
    defer></script>
)}

{pseudocode && (
  <>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/pseudocode@2.4.1/build/pseudocode.min.css"
      integrity="sha384-ff9LEHNvuDqxJT/JRjAeQ1cWTWambRLe5j49SnOzhaotb23KEQkCanV+ooL+ch4k"
      crossorigin="anonymous"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/pseudocode@2.4.1/build/pseudocode.min.js"
      integrity="sha384-i3+YbLfC66kxqBVtgH6I+lEFAr+57mVZY/MSthCK/oTPo0rWCRzW/kSg2mJnTKLs"
      crossorigin="anonymous"
      defer></script>
  </>
)}

{typograms && (
  <script src="/assets/js/typograms.js" type="module"></script>
)}

{tikzjax && (
  <>
    {/* tikzjax uses unversioned URLs — SRI cannot be pinned; self-host if supply-chain integrity is critical */}
    <link rel="stylesheet" href="https://tikzjax.com/v1/fonts.css" />
    <script src="https://tikzjax.com/v1/tikzjax.js"></script>
  </>
)}

{map && (
  <>
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha384-sHL9NAb7lN7rfvG5lfHpm643Xkcjzp4jFvuavGOndn6pjVqS6ny56CAt3nsEVT4H"
      crossorigin="anonymous"
    />
    <script
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha384-cxOPjt7s7Iz04uaHJceBmS+qpjv2JkIHNVcuOrM+YHwZOmJGBXI00mdUXEq65HTH"
      crossorigin="anonymous"
      defer></script>
  </>
)}

{img_comparison && (
  <>
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/index.js"
      integrity="sha384-FCXElAg99YO+h+5Ky3gZ9cVwc8wyg6sq3jn79ugH0u5jh0NR5cvr0hGP+tzpjI+A"
      crossorigin="anonymous"></script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/styles.css"
      integrity="sha384-TYCxyqTqCrHZ0yHG2B7VENYnxnIBGWt8GHLLkGegAYCw+1UkvUd0YpsVPrt+8//z"
      crossorigin="anonymous"
    />
  </>
)}

{code_diff && (
  <>
    {/* pinned to diff2html@3.4.56 — update SRI when upgrading */}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/diff2html@3.4.56/bundles/css/diff2html.min.css"
      integrity="sha384-PdRCG/+r1waybtXfuDB9Kmv2h7AGoN6WaTZ5OF+ctPeR9BGne0FaKRQnUeGV4nDL"
      crossorigin="anonymous"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/diff2html@3.4.56/bundles/js/diff2html-ui.min.js"
      integrity="sha384-NRd5i/CwvZ20mJEQt3yaDU1LeU+tu0bqyVYojXi8d7Lf1B0/TIs2K3FTvlf8aO7p"
      crossorigin="anonymous"
      defer></script>
  </>
)}

{gallery && (
  <>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.css"
      integrity="sha384-IfxC36XL/toUyJ939C73PcgMuRzAZuIzZxE38drsmO5p6jD7ei+Zx/1oA/0l8ysE"
      crossorigin="anonymous"
    />
    {/* photoswipe ESM imports are inline dynamic imports — SRI not applicable to dynamic import() */}
    <script type="module">{`
      import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe-lightbox.esm.js';
      const lightbox = new PhotoSwipeLightbox({
        gallery: '#post-content',
        children: 'a[data-pswp-width]',
        pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.esm.js'),
      });
      lightbox.init();
    `}</script>
  </>
)}

{disqus && (
  <>
    <div id="disqus_thread" class="mt-8 pt-6" style="border-top: 1px solid var(--global-divider-color);"></div>
    <script is:inline define:vars={{ disqusUrl: Astro.url.href, disqusId: post.id, disqusShortname: site.comments.disqusShortname }}>
      var disqus_config = function () {
        this.page.url = disqusUrl;
        this.page.identifier = disqusId;
      };
      (function() {
        var d = document, s = d.createElement('script');
        s.src = `https://${disqusShortname}.disqus.com/embed.js`;
        s.setAttribute('data-timestamp', +new Date());
        (d.head || d.body).appendChild(s);
      })();
    </script>
  </>
)}

<style>
  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s;
    font-size: 0.7rem;
    font-family: var(--font-mono, monospace);
    background-color: var(--global-card-bg-color, #f5f5f5);
    color: var(--global-text-color-light, #888);
    line-height: 1.5;
  }
  pre:hover .copy-btn {
    opacity: 1;
  }
  .copy-btn:hover {
    background-color: var(--global-theme-color);
    color: var(--global-hover-text-color, #fff);
  }
</style>

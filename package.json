{
  "name": "as-folio",
  "description": "A clean, responsive Astro template for academics and researchers",
  "version": "1.0.0",
  "author": "Dadang NH <hello@dadangnh.com>",
  "homepage": "https://github.com/dadangnh/as-folio",
  "repository": {
    "type": "git",
    "url": "https://github.com/dadangnh/as-folio"
  },
  "keywords": [
    "astro",
    "academic",
    "portfolio",
    "template",
    "as-folio"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "lint:ci": "eslint . --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "astro check && tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=junit",
    "test:all": "yarn test:types && yarn lint:ci && yarn test && yarn test:e2e",
    "validate": "yarn test:all",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/partytown": "^2.1.5",
    "@astrojs/react": "^5.0.1",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@iconify-json/academicons": "^1.2.1",
    "@iconify-json/fa-brands": "^1.2.2",
    "@iconify-json/fa-regular": "^1.2.1",
    "@iconify-json/fa-solid": "^1.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "astro": "6.0.8",
    "astro-icon": "^1.1.4",
    "js-yaml": "^4.1.0",
    "medium-zoom": "^1.1.0",
    "ninja-keys": "^1.2.1",
    "node-addon-api": "^8.6.0",
    "notebookjs": "^0.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.1.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.0",
    "astro-eslint-parser": "^1.1.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "pagefind": "^1.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.6",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.0.0"
  }
}
